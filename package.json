{
  "name": "blackbox",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=@blackbox/api",
    "dev:web": "npm run dev --workspace=@blackbox/web",
    "build": "npm run build --workspaces",
    "test": "npm test --workspaces",
    "postinstall": "npm run prisma:generate --workspace=@blackbox/api"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "prettier": "^3.2.5",
    "eslint": "^8.56.0"
  }
}
