generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                    String    @id
  name                  String
  githubInstallationId  String?   @unique
  githubOrgLogin        String?
  slackTeamId           String?   @unique
  slackBotToken         String?   // encrypted
  jiraSiteUrl           String?
  jiraEmail             String?
  jiraToken             String?   // encrypted
  settings              Json      @default("{}")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  users                 User[]
  decisionRecords       DecisionRecord[]
  projects              Project[]
  apiKeys               ApiKey[]
  @@map("organizations")
}

model User {
  id              String    @id
  orgId           String    @map("org_id")
  email           String
  name            String?
  githubLogin     String?   @map("github_login")
  githubUserId    Int?      @map("github_user_id")
  slackUserId     String?   @map("slack_user_id")
  avatarUrl       String?   @map("avatar_url")
  role            String    @default("engineer")
  bio             String?
  website         String?
  twitter         String?
  linkedin        String?
  location        String?
  lastSeenAt      DateTime? @map("last_seen_at")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  org             Organization @relation(fields: [orgId], references: [id])
  projectsCreated Project[]    @relation("ProjectCreator")
  projectMemberships ProjectMember[]
  apiKeys         ApiKey[]
  @@map("users")
}

model DecisionRecord {
  id                      String    @id
  orgId                   String
  title                   String
  summaryOneLiner         String?
  what                    String?
  why                     String?
  alternativesConsidered  String[]  @default([])
  tradeoffs               String?
  outcome                 String?
  decisionType            String    @default("architecture")
  impact                  String    @default("medium")
  tags                    String[]  @default([])
  confidence              Float     @default(0)
  aiModel                 String?
  dataSources             String[]  @default([])
  status                  String    @default("pending_review")
  authorGithubLogin       String?
  confirmedByUserId       String?
  confirmedAt             DateTime?
  editHistory             Json      @default("[]")
  linkedPrNumber          Int?
  linkedRepo              String?
  linkedCommitSha         String?
  linkedTicketId          String?
  linkedSlackThreadTs     String?
  filesAffected           String[]  @default([])
  supersedesId            String?
  supersededById          String?
  projectId               String?   @map("project_id")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  org                     Organization @relation(fields: [orgId], references: [id])
  project                 Project?     @relation(fields: [projectId], references: [id])
  @@map("decision_records")
}

model PendingNudge {
  id               String    @id
  orgId            String
  recordId         String
  slackUserId      String
  slackMessageTs   String?
  status           String    @default("sent")
  expiresAt        DateTime
  respondedAt      DateTime?
  createdAt        DateTime  @default(now())
  @@map("pending_nudges")
}

model Project {
  id              String    @id @default(dbgenerated("gen_random_uuid()"))
  orgId           String    @map("org_id")
  name            String
  description     String?
  slug            String
  status          String    @default("active")
  githubRepoId    Int?      @map("github_repo_id")
  githubRepoOwner String?   @map("github_repo_owner")
  githubRepoName  String?   @map("github_repo_name")
  lastSyncedAt    DateTime? @map("last_synced_at")
  createdBy       String?   @map("created_by")
  createdAt       DateTime? @default(now()) @map("created_at")
  updatedAt       DateTime? @default(now()) @updatedAt @map("updated_at")
  org             Organization @relation(fields: [orgId], references: [id])
  creator         User?     @relation("ProjectCreator", fields: [createdBy], references: [id])
  decisionRecords DecisionRecord[]
  members         ProjectMember[]
  @@map("projects")
}

model ProjectMember {
  id              String    @id @default(dbgenerated("gen_random_uuid()"))
  projectId       String    @map("project_id")
  userId          String    @map("user_id")
  role            String    @default("engineer")
  customRoleName  String?   @map("custom_role_name")
  joinedAt        DateTime? @default(now()) @map("joined_at")
  project         Project   @relation(fields: [projectId], references: [id])
  user            User      @relation(fields: [userId], references: [id])
  @@unique([projectId, userId])
  @@map("project_members")
}

model ApiKey {
  id              String    @id @default(dbgenerated("gen_random_uuid()"))
  userId          String    @map("user_id")
  orgId          String    @map("org_id")
  name            String
  keyHash         String    @unique @map("key_hash")
  lastUsedAt      DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  createdAt       DateTime? @default(now()) @map("created_at")
  deletedAt       DateTime? @map("deleted_at")
  user            User      @relation(fields: [userId], references: [id])
  org             Organization @relation(fields: [orgId], references: [id])
  @@map("api_keys")
}

model AuditLog {
  id         String    @id
  orgId      String    @map("org_id")
  actorId    String?   @map("actor_id")
  action     String
  targetId   String?   @map("target_id")
  metadata   Json      @default("{}")
  ipAddress  String?   @map("ip_address")
  createdAt  DateTime  @default(now()) @map("created_at")
  @@map("audit_logs")
}
